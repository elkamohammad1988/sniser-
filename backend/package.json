{
  "name": "sniser-backend",
  "version": "1.0.0",
  "description": "Production-ready Express + TypeScript API for the Sniser platform",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"tests/**/*.test.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
