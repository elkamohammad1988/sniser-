# ==============================================================================
# Sniser API — environment configuration
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Every variable below is validated at boot by src/config/env.ts (fails fast).
# ==============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=4000

# --- HTTP ---
# Comma-separated list of allowed CORS origins. Use "*" only for local dev.
CORS_ORIGIN=http://localhost:5173
API_PREFIX=/api
BODY_LIMIT=1mb

# Public URL of the SPA (used to build links in emails).
APP_URL=http://localhost:5173
# Public URL of THIS API (used to build absolute upload URLs). Optional.
# PUBLIC_API_URL=http://localhost:4000

# --- Logging ---
# Levels: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- Rate limiting (applied to /api/*) ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Database (SQLite) ---
DATABASE_PATH=./data/sniser.db
# Run migrations automatically on boot.
DB_AUTO_MIGRATE=true
# Seed reference data + DEMO accounts when the DB is empty.
# IMPORTANT: set to `false` in production — the demo accounts use publicly
# known passwords and are for local/staging showcase only.
DB_AUTO_SEED=true

# --- Auth (JWT access + opaque refresh tokens) ---
# REQUIRED in production (boot fails without them). Each must be >= 32 chars.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_ACCESS_SECRET=replace-with-a-long-random-string-at-least-32-chars
# JWT_REFRESH_SECRET=replace-with-a-different-long-random-string-32-chars
JWT_ACCESS_TTL=15m
# Refresh token lifetime, in days.
REFRESH_TTL_DAYS=30

# --- Cookies ---
# COOKIE_DOMAIN=.yourdomain.com
# Force the Secure flag on cookies (defaults to true in production).
# COOKIE_SECURE=true

# --- Email (SMTP). If unset, mail is written to MAIL_OUTBOX_DIR instead. ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# SMTP_SECURE=false
MAIL_FROM=Sniser <no-reply@sniser.io>
MAIL_OUTBOX_DIR=./data/outbox

# --- Uploads ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=15

# --- Marketplace economics (basis points; 250 = 2.5%) ---
PLATFORM_FEE_BPS=250
RESALE_FEE_BPS=500
# Max wallet top-up per request, in whole currency units.
MAX_DEPOSIT=10000

# --- Bootstrap admin (seeded once, only if the users table is empty) ---
ADMIN_EMAIL=admin@sniser.io
# CHANGE THIS before any non-local deploy. Min 8 chars.
ADMIN_PASSWORD=ChangeMe!2026
