# Public env vars must be prefixed with VITE_ to be exposed to the client bundle.
# Anything in this file ends up in the JS sent to users — never put secrets here.

# Base URL of the Sniser API (no trailing slash). Defaults to localhost for dev.
VITE_API_URL=http://localhost:4000/api/v1

# Contact link used by the WhatsApp CTA button.
VITE_WHATSAPP_URL=https://wa.me/447000000000

# Optional: canonical site origin used by per-route SEO tags.
# VITE_SITE_URL=https://sniser.example.com

# --- Optional CTA / auth entry points (unset → buttons render a safe "#") ---
# VITE_AUTH_SIGNUP_URL=
# VITE_AUTH_LOGIN_URL=
# VITE_ADVERTISE_URL=
# VITE_WALLET_CONNECT_URL=

# --- Optional social links (unset → hidden / inert) ---
# VITE_SOCIAL_INSTAGRAM=
# VITE_SOCIAL_FACEBOOK=
# VITE_SOCIAL_TWITTER=
# VITE_SOCIAL_LINKEDIN=
